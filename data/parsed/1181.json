  "training_techniques": [
    {
      "category": "architecture_modification",
      "data": {
        "component": "depth recurrence",
        "description": "Layers 4 and 5 are repeated once to create 13 virtual layers from 11 physical layers.",
        "parameters": {
          "layers": [
            4,
            5
          ],
          "repeats": 1,
          "virtual_layers": 13,
          "physical_layers": 11
        }
      }
    },
    {
      "category": "architecture_modification",
      "data": {
        "component": "LoRA",
        "description": "Rank-2 low-rank corrective adapters are added on attention projections for the recurrent pass.",
        "parameters": {
          "rank": 2,
          "targets": [
            "Q",
            "K",
            "V",
            "O"
          ]
        }
      }
    },
    {
      "category": "architecture_modification",
      "data": {
        "component": "RMSNorm",
        "description": "RMSNorm is applied before re-entering the shared recurrent block to reduce distribution drift.",
        "parameters": null
      }
    },
    {
      "category": "regularization",
      "data": {
        "method": "layerwise LN scale",
        "parameters": {
          "learnable_alpha": true,
          "alpha_init": 0.6
        }
      }
    },
    {
      "category": "quantization",
      "data": {
        "method": "GPTQ",
        "bits": 6,
        "scope": "block weights"
      }
    },
    {
